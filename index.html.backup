<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>War Era - Country Alliance Network (3D)</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow: hidden;
            background: #000;
            color: #fff;
        }
        #info-panel {
            position: absolute;
            top: 20px;
            left: 20px;
            background: rgba(0, 0, 0, 0.8);
            border: 1px solid rgba(0, 200, 255, 0.5);
            border-radius: 10px;
            padding: 20px;
            max-width: 320px;
            backdrop-filter: blur(10px);
            box-shadow: 0 0 20px rgba(0, 200, 255, 0.3);
        }
        h1 {
            font-size: 1.2em;
            margin-bottom: 10px;
            color: #0ff;
            text-shadow: 0 0 10px rgba(0, 255, 255, 0.7);
        }
        p {
            font-size: 0.9em;
            line-height: 1.5;
            color: #ccc;
            margin-bottom: 15px;
        }
        #country-info {
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid rgba(255, 255, 255, 0.2);
            min-height: 100px;
        }
        #country-info h3 {
            color: #f0f;
            margin-bottom: 8px;
            font-size: 1.1em;
        }
        #country-info .stat {
            display: flex;
            justify-content: space-between;
            margin: 5px 0;
            font-size: 0.85em;
        }
        .stat-label {
            color: #888;
        }
        .stat-value {
            color: #fff;
            font-weight: bold;
        }
        .ally-tag {
            display: inline-block;
            background: rgba(0, 200, 255, 0.2);
            border: 1px solid rgba(0, 200, 255, 0.5);
            padding: 3px 8px;
            margin: 2px;
            border-radius: 4px;
            font-size: 0.8em;
            color: #0ff;
        }
        #loading {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 1.5em;
            color: #0ff;
            text-align: center;
        }
        .loader {
            width: 50px;
            height: 50px;
            border: 3px solid rgba(0, 200, 255, 0.3);
            border-top-color: #0ff;
            border-radius: 50%;
            margin: 20px auto;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        #stats {
            position: absolute;
            bottom: 20px;
            right: 20px;
            background: rgba(0, 0, 0, 0.7);
            padding: 15px;
            border-radius: 8px;
            font-size: 0.85em;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        .instruction {
            position: absolute;
            bottom: 20px;
            left: 20px;
            font-size: 0.8em;
            color: #666;
            background: rgba(0, 0, 0, 0.5);
            padding: 10px;
            border-radius: 5px;
        }
    </style>
</head>
<body>
    <div id="loading">
        <div class="loader"></div>
        <div>Loading War Era alliance data...</div>
    </div>

    <div id="info-panel" style="display: none;">
        <h1>🌍 War Era Alliance Network</h1>
        <p>3D visualization of country alliances. Each node is a country, colored by region. Lines represent alliances.</p>
        <div id="country-info">
            <p style="color: #666; font-style: italic;">Click a country to view details</p>
        </div>
    </div>

    <div id="stats" style="display: none;">
        <div>Countries: <span id="node-count">0</span></div>
        <div>Alliances: <span id="edge-count">0</span></div>
    </div>

    <div class="instruction">
        🖱️ Drag to rotate • Scroll to zoom • Click nodes for details
    </div>

    <!-- Three.js from CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/libs/stats.min.js"></script>

    <script>
        // Global variables
        let scene, camera, renderer, controls;
        let countries = [];
        let alliances = [];
        let nodes = {};
        let edges = {};
        let raycaster, mouse;
        let selectedNode = null;
        let isDragging = false;

        // Color palette for regions (arbitrary grouping)
        const regionColors = [
            0xff0066, // pink
            0x00ff99, // green
            0x00ccff, // cyan
            0xffcc00, // yellow
            0xff6600, // orange
            0x9966ff, // purple
            0xff3366, // red
            0x66ffcc, // teal
            0xffff00, // bright yellow
            0xff6600  // deeper orange
        ];

        async function fetchWarEraData() {
            try {
                // Fetch all countries
                const response = await fetch('https://api2.warera.io/country.getAllCountries');
                if (!response.ok) throw new Error('Failed to fetch countries');
                const data = await response.json();

                console.log('API Response:', data);

                // Extract countries array - check for different response formats
                let countriesList = [];
                if (data.result && data.result.data) {
                    countriesList = data.result.data;
                } else if (Array.isArray(data)) {
                    countriesList = data;
                } else if (data.countries) {
                    countriesList = data.countries;
                } else {
                    console.warn('Unexpected response format, trying to extract countries');
                    countriesList = data;
                }

                console.log(\`Found \${countriesList.length} countries\`);

                // Build network: nodes = countries, edges = alliances
                const network = { nodes: [], edges: [] };
                const countryMap = {};

                countriesList.forEach((country, index) => {
                    const id = country._id || country.id || \`country-\${index}\`;
                    const name = country.name || country.code || \`Country \${index}\`;

                    countryMap[id] = country;

                    network.nodes.push({
                        id: id,
                        name: name,
                        code: country.code || '',
                        money: country.money || 0,
                        allies: country.allies || [],
                        warsWith: country.warsWith || [],
                        region: country.region || index % regionColors.length
                    });
                });

                // Create edges from alliances
                network.nodes.forEach(node => {
                    node.allies.forEach(allyId => {
                        if (countryMap[allyId]) {
                            // Create edge only if both nodes exist and avoid duplicates
                            const edgeId = [node.id, allyId].sort().join('-');
                            if (!edges[edgeId]) {
                                edges[edgeId] = true;
                                network.edges.push({
                                    source: node.id,
                                    target: allyId
                                });
                            }
                        }
                    });
                });

                console.log(\`Network: \${network.nodes.length} nodes, \${network.edges.length} edges\`);
                return network;

            } catch (error) {
                console.error('Error fetching data:', error);
                // Generate mock data for demonstration
                console.log('Using mock data instead');
                return generateMockData();
            }
        }

        function generateMockData() {
            // Create a realistic mock network with ~50 countries
            const names = [
                'Alpha', 'Beta', 'Gamma', 'Delta', 'Epsilon', 'Zeta', 'Eta', 'Theta',
                'Iota', 'Kappa', 'Lambda', 'Mu', 'Nu', 'Xi', 'Omicron', 'Pi',
                'Rho', 'Sigma', 'Tau', 'Upsilon', 'Phi', 'Chi', 'Psi', 'Omega'
            ];
            const colors = Array.from({length: 50}, (_, i) => i % regionColors.length);

            const nodes = [];
            const edges = [];

            for (let i = 0; i < 50; i++) {
                nodes.push({
                    id: \`mock-\${i}\`,
                    name: \`\${names[i % names.length]}\${i}\`,
                    code: names[i % names.length].substring(0, 3).toUpperCase(),
                    money: Math.floor(Math.random() * 1000000),
                    allies: [],
                    warsWith: [],
                    region: colors[i]
                });
            }

            // Random alliances (each country gets 2-5 allies)
            nodes.forEach((node, i) => {
                const numAllies = 2 + Math.floor(Math.random() * 4);
                const allies = new Set();
                while (allies.size < numAllies) {
                    const otherIdx = Math.floor(Math.random() * nodes.length);
                    if (otherIdx !== i) {
                        allies.add(nodes[otherIdx].id);
                    }
                }
                node.allies = Array.from(allies);
            });

            // Build edges
            nodes.forEach(node => {
                node.allies.forEach(allyId => {
                    const edgeId = [node.id, allyId].sort().join('-');
                    if (!edges.find(e => e.source === node.id && e.target === allyId)) {
                        edges.push({ source: node.id, target: allyId });
                    }
                });
            });

            return { nodes, edges };
        }

        function initScene() {
            // Scene setup
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x000510);
            scene.fog = new THREE.FogExp2(0x000510, 0.0015);

            // Camera
            camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 2000);
            camera.position.set(0, 200, 400);

            // Renderer
            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            document.body.appendChild(renderer.domElement);

            // Controls
            controls = new THREE.OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.dampingFactor = 0.05;
            controls.minDistance = 50;
            controls.maxDistance = 1000;

            // Lighting
            const ambientLight = new THREE.AmbientLight(0x404040, 0.5);
            scene.add(ambientLight);

            const pointLight = new THREE.PointLight(0xffffff, 1, 1000);
            pointLight.position.set(100, 200, 100);
            scene.add(pointLight);

            // Raycaster for mouse picking
            raycaster = new THREE.Raycaster();
            mouse = new THREE.Vector2();

            // Event listeners
            window.addEventListener('resize', onWindowResize);
            window.addEventListener('click', onMouseClick);

            // Drag detection
            renderer.domElement.addEventListener('mousedown', () => isDragging = true);
            renderer.domElement.addEventListener('mouseup', () => isDragging = false);
        }

        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function onMouseClick(event) {
            mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
            mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;

            raycaster.setFromCamera(mouse, camera);
            const intersects = raycaster.intersectObjects(scene.children);

            for (let i = 0; i < intersects.length; i++) {
                const obj = intersects[i].object;
                if (obj.userData.countryId) {
                    selectCountry(obj.userData.countryId);
                    break;
                }
            }
        }

        function selectCountry(countryId) {
            selectedNode = countryId;
            const country = countries.find(c => c.id === countryId);
            if (!country) return;

            // Highlight selected node
            Object.values(nodes).forEach(node => {
                if (node.userData.countryId === countryId) {
                    node.material.emissive.setHex(0xffff00);
                    node.material.emissiveIntensity = 0.5;
                } else {
                    node.material.emissive.setHex(0x000000);
                }
            });

            // Update info panel
            const infoDiv = document.getElementById('country-info');
            const alliesList = country.allies.map(allyId => {
                const ally = countries.find(c => c.id === allyId);
                return ally ? ally.name : allyId;
            }).filter(Boolean);

            infoDiv.innerHTML = \`
                <h3>\${country.name} \${country.code ? '('+country.code+')' : ''}</h3>
                <div class="stat">
                    <span class="stat-label">Region:</span>
                    <span class="stat-value">\${country.region + 1}</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Treasury:</span>
                    <span class="stat-value">$\${Number(country.money).toLocaleString()}</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Alliances:</span>
                    <span class="stat-value">\${country.allies.length}</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Wars:</span>
                    <span class="stat-value">\${country.warsWith.length}</span>
                </div>
                <div style="margin-top: 10px;">
                    <span class="stat-label">Allied with:</span>
                </div>
                <div>
                    \${alliesList.length > 0 ? alliesList.map(a => \`<span class="ally-tag">\${a}</span>\`).join('') : '<span style="color:#666; font-size:0.8em;">None</span>'}
                </div>
            \`;
        }

        function createNetwork(network) {
            countries = network.nodes;
            alliances = network.edges;

            // Update stats display
            document.getElementById('node-count').textContent = countries.length;
            document.getElementById('edge-count').textContent = alliances.length;

            // Store for later use
            window.countries = countries;

            // Create nodes on a sphere surface
            const sphereRadius = 200;
            const nodeGeometry = new THREE.SphereGeometry(3, 16, 16);

            countries.forEach((country, i) => {
                // Distribute nodes on sphere using Fibonacci spiral
                const phi = Math.acos(1 - 2 * (i + 0.5) / countries.length);
                const theta = Math.PI * (1 + Math.sqrt(5)) * (i + 0.5);

                const x = sphereRadius * Math.sin(phi) * Math.cos(theta);
                const y = sphereRadius * Math.sin(phi) * Math.sin(theta);
                const z = sphereRadius * Math.cos(phi);

                // Jitter positions slightly to avoid perfect overlap
                const jitter = () => (Math.random() - 0.5) * 10;
                const pos = new THREE.Vector3(x + jitter(), y + jitter(), z + jitter());

                // Color by region
                const color = new THREE.Color(regionColors[country.region % regionColors.length]);

                const material = new THREE.MeshPhongMaterial({
                    color: color,
                    emissive: color,
                    emissiveIntensity: 0.3,
                    shininess: 100
                });

                const sphere = new THREE.Mesh(nodeGeometry, material);
                sphere.position.copy(pos);
                sphere.userData.countryId = country.id;
                sphere.userData.country = country;
                scene.add(sphere);

                nodes[country.id] = sphere;

                // Add glow effect
                const glowGeometry = new THREE.SphereGeometry(4, 16, 16);
                const glowMaterial = new THREE.MeshBasicMaterial({
                    color: color,
                    transparent: true,
                    opacity: 0.2
                });
                const glow = new THREE.Mesh(glowGeometry, glowMaterial);
                glow.position.copy(pos);
                scene.add(glow);
            });

            // Create edges (alliances)
            const edgeMaterial = new THREE.LineBasicMaterial({
                color: 0x00ffff,
                transparent: true,
                opacity: 0.3
            });

            alliances.forEach(edge => {
                const sourceNode = nodes[edge.source];
                const targetNode = nodes[edge.target];

                if (sourceNode && targetNode) {
                    const geometry = new THREE.BufferGeometry().setFromPoints([
                        sourceNode.position,
                        targetNode.position
                    ]);
                    const line = new THREE.Line(geometry, edgeMaterial);
                    scene.add(line);
                    edges[edge.source + '-' + edge.target] = line;
                }
            });

            // Add labels (using sprites)
            const labelDiv = document.createElement('div');
            labelDiv.style.position = 'absolute';
            labelDiv.style.color = '#fff';
            labelDiv.style.fontSize = '10px';
            labelDiv.style.fontFamily = 'monospace';
            labelDiv.style.pointerEvents = 'none';
            document.body.appendChild(labelDiv);

            countries.forEach(country => {
                const node = nodes[country.id];
                if (!node) return;

                const canvas = document.createElement('canvas');
                const ctx = canvas.getContext('2d');
                canvas.width = 256;
                canvas.height = 64;

                ctx.fillStyle = 'rgba(0,0,0,0)';
                ctx.fillRect(0, 0, canvas.width, canvas.height);
                ctx.fillStyle = 'white';
                ctx.font = 'bold 32px monospace';
                ctx.textAlign = 'center';
                ctx.fillText(country.code || country.name.substring(0, 8), 128, 40);

                const texture = new THREE.CanvasTexture(canvas);
                const spriteMaterial = new THREE.SpriteMaterial({ map: texture, transparent: true });
                const sprite = new THREE.Sprite(spriteMaterial);
                sprite.position.copy(node.position).add(new THREE.Vector3(0, 8, 0));
                sprite.scale.set(30, 7.5, 1);
                scene.add(sprite);
            });
        }

        function animate() {
            requestAnimationFrame(animate);

            controls.update();

            // Rotate scene slowly when not interacting
            if (!controls.enabled || !isDragging) {
                scene.rotation.y += 0.0005;
            }

            // Pulse glow effect
            const time = Date.now() * 0.001;
            Object.values(nodes).forEach((node, idx) => {
                if (node.userData.countryId !== selectedNode) {
                    const pulse = 0.2 + 0.1 * Math.sin(time + idx * 0.1);
                    node.material.emissiveIntensity = pulse;
                }
            });

            renderer.render(scene, camera);
        }

        // Main initialization
        async function main() {
            initScene();

            const network = await fetchWarEraData();

            document.getElementById('loading').style.display = 'none';
            document.getElementById('info-panel').style.display = 'block';
            document.getElementById('stats').style.display = 'block';

            createNetwork(network);
            animate();
        }

        main();
    </script>
</body>
</html>
